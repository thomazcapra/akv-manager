{
  "name": "akv-manager",
  "version": "0.0.1",
  "description": "Local web console to browse and manage Azure Key Vaults — secrets, keys, certificates, expiry — using your own az login. No credentials are stored.",
  "type": "commonjs",
  "main": "server.js",
  "bin": {
    "akv-manager": "server.js"
  },
  "files": [
    "server.js",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "author": "Thomaz Capra",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "keywords": [
    "azure",
    "keyvault",
    "key-vault",
    "secrets",
    "certificates",
    "az",
    "azure-cli",
    "dashboard",
    "cli"
  ],
  "dependencies": {
    "express": "^4.19.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
